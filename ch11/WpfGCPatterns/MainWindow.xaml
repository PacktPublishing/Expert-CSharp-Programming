<!-- ============================================================
     MainWindow.xaml
     Demonstrates GC interaction patterns in a WPF application:

     • A smooth animation loop that requires low-latency GC
     • A CPU-heavy background task that is offloaded to prevent
       UI-thread stalls caused by large allocations
     • A recycling virtualized list renderer to reduce per-render
       allocations that could cause frame drops
     ============================================================ -->
<Window x:Class="WpfGCPatterns.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WPF GC Patterns Demo" Height="480" Width="700"
        Loaded="OnLoaded">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0" Text="WPF GC Patterns Demo"
                   FontSize="22" FontWeight="Bold" Margin="0,0,0,12"/>

        <!-- GC Stats -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="GC Mode: " FontWeight="SemiBold"/>
            <TextBlock x:Name="GcModeText" Text="(loading)"/>
            <TextBlock Text="   Latency: " FontWeight="SemiBold" Margin="16,0,0,0"/>
            <TextBlock x:Name="LatencyText" Text="(loading)"/>
        </StackPanel>

        <!-- Controls -->
        <WrapPanel Grid.Row="2" Margin="0,0,0,12">
            <Button x:Name="StartAnimationLowLatencyButton"
                    Content="▶ Start Animation (SustainedLowLatency, not No-GC)"
                    Padding="10,6" Margin="0,0,8,0"
                    Click="OnStartAnimationLowLatency"/>
            <Button x:Name="StartAnimationDefaultButton"
                    Content="▶ Start Animation (Default Latency)"
                    Padding="10,6" Margin="0,0,8,0"
                    Click="OnStartAnimationDefault"/>
            <Button x:Name="StopAnimationButton"
                    Content="⏹ Stop Animation"
                    Padding="10,6" Margin="0,0,8,0"
                    IsEnabled="False"
                    Click="OnStopAnimation"/>
            <Button x:Name="HeavyWorkButton"
                    Content="⚙ Background Work (no UI stall)"
                    Padding="10,6" Margin="0,0,8,0"
                    Click="OnHeavyWork"/>
            <Button x:Name="LeakDemoButton"
                    Content="⚠ Simulate Event Leak"
                    Padding="10,6" Margin="0,0,8,0"
                    Click="OnSimulateLeak"/>
            <Button x:Name="IncreasePressureButton"
                    Content="📈 Increase Memory Pressure"
                    Padding="10,6" Margin="0,0,8,0"
                    Click="OnIncreaseMemoryPressure"/>
            <Button x:Name="ForceGcButton"
                    Content="🧪 Force Gen2 GC"
                    Padding="10,6"
                    Click="OnForceGc"/>
        </WrapPanel>

        <!-- Real WPF animation preview -->
        <Border Grid.Row="3" BorderBrush="#FFD0D0D0" BorderThickness="1" CornerRadius="6" Padding="8" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="Real WPF animation (SustainedLowLatency reduces blocking pauses; GC can still run)" FontWeight="SemiBold" Margin="0,0,0,6"/>
                <Canvas Height="56" Background="#FFF8F8F8" ClipToBounds="True">
                    <Ellipse Width="20" Height="20" Fill="#FF2D7DFF" Canvas.Left="8" Canvas.Top="18">
                        <Ellipse.RenderTransform>
                            <TranslateTransform x:Name="DotTransform"/>
                        </Ellipse.RenderTransform>
                    </Ellipse>
                </Canvas>
            </StackPanel>
        </Border>

        <!-- Live heap metrics -->
        <ListBox Grid.Row="4" x:Name="MetricsListBox"
                 FontFamily="Consolas" FontSize="12"
                 VirtualizingPanel.IsVirtualizing="True"
                 VirtualizingPanel.VirtualizationMode="Recycling"/>

        <!-- Status bar -->
        <StatusBar Grid.Row="5">
            <StatusBarItem>
                <TextBlock x:Name="StatusText" Text="Ready."/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
