@page "/books/create"
@rendermode InteractiveWebAssembly
@inject IBooksService Client
@inject NavigationManager Nav

<h3>Create Book</h3>

@if (_error is not null)
{
    <div class="alert alert-danger">@_error</div>
}

<EditForm Model="_model" OnValidSubmit="HandleValidSubmit">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <div class="mb-3">
        <label class="form-label" for="title">Title</label>
        <InputText id="title" class="form-control" @bind-Value="_model.Title" />
    </div>
    <div class="mb-3">
        <label class="form-label" for="publisher">Publisher</label>
        <InputText id="publisher" class="form-control" @bind-Value="_model.Publisher" />
    </div>

    <button type="submit" class="btn btn-primary">Save</button>
    <button type="button" class="btn btn-secondary ms-2" @onclick="Cancel">Cancel</button>
</EditForm>

@code {
    private Book _model = new("");
    private string? _error;

    private async Task HandleValidSubmit()
    {
        _error = null;
        try
        {
            var created = await Client.CreateBookAsync(_model);
            Nav.NavigateTo("/books");
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    private void Cancel() => Nav.NavigateTo("/books");
}
